{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "skill_name": "haos_iip_skill",
  "version": "0.1.0",
  "description": "Deterministic wrapper over the frozen stability oracle for bounded agent evaluation.",
  "tools": [
    {
      "name": "evaluate_structure",
      "description": "Evaluate a single graph-like state specification for recoverable structural coherence.",
      "input_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "state_spec"
        ],
        "properties": {
          "state_spec": {
            "$ref": "#/$defs/state_spec"
          },
          "timeout_seconds": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      },
      "output_schema": {
        "$ref": "#/$defs/stability_report"
      }
    },
    {
      "name": "scan_structure",
      "description": "Evaluate a bounded batch of concrete state specifications without mutating any frozen research artifacts.",
      "input_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "cases"
        ],
        "properties": {
          "cases": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "state_spec"
              ],
              "properties": {
                "case_id": {
                  "type": "string"
                },
                "state_spec": {
                  "$ref": "#/$defs/state_spec"
                },
                "timeout_seconds": {
                  "type": "number",
                  "exclusiveMinimum": 0
                }
              }
            }
          },
          "timeout_seconds": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      },
      "output_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_count",
          "counts",
          "cases"
        ],
        "properties": {
          "case_count": {
            "type": "integer",
            "minimum": 1
          },
          "counts": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "stable",
              "marginal",
              "unstable"
            ],
            "properties": {
              "stable": {
                "type": "integer",
                "minimum": 0
              },
              "marginal": {
                "type": "integer",
                "minimum": 0
              },
              "unstable": {
                "type": "integer",
                "minimum": 0
              }
            }
          },
          "cases": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "case_id",
                "report"
              ],
              "properties": {
                "case_id": {
                  "type": "string"
                },
                "report": {
                  "$ref": "#/$defs/stability_report"
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "state_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nodes",
        "edges"
      ],
      "properties": {
        "plan_id": {
          "type": "string"
        },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "step_type"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "step_type": {
                "type": "string",
                "minLength": 1
              },
              "reversible": {
                "type": "boolean"
              },
              "checkpoint": {
                "type": "boolean"
              },
              "invariant_tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "risk_weight": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source",
              "target"
            ],
            "properties": {
              "source": {
                "type": "string",
                "minLength": 1
              },
              "target": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "stability_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classification",
        "structural_retention",
        "temporal_consistency",
        "causal_deformation",
        "geometric_integrity",
        "summary"
      ],
      "properties": {
        "classification": {
          "type": "string",
          "enum": [
            "stable",
            "marginal",
            "unstable"
          ]
        },
        "structural_retention": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "temporal_consistency": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "causal_deformation": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "geometric_integrity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "summary": {
          "type": "string"
        }
      }
    }
  }
}
