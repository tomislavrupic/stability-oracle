{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "skill_name": "haos_stability_skill",
  "version": "0.1.0",
  "tools": [
    {
      "name": "evaluate_structure",
      "description": "Evaluate recoverable structural coherence.",
      "input_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "state_spec"
        ],
        "properties": {
          "state_spec": {
            "type": "object",
            "description": "Opaque state object passed to the external HAOS oracle."
          },
          "timeout": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      },
      "output_schema": {
        "$ref": "#/$defs/stability_report"
      }
    },
    {
      "name": "scan_structure",
      "description": "Evaluate a bounded batch of structural configurations.",
      "input_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "cases"
        ],
        "properties": {
          "cases": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "state_spec"
              ],
              "properties": {
                "case_id": {
                  "type": "string"
                },
                "state_spec": {
                  "type": "object"
                },
                "timeout": {
                  "type": "number",
                  "exclusiveMinimum": 0
                }
              }
            }
          }
        }
      },
      "output_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_count",
          "counts",
          "cases"
        ],
        "properties": {
          "case_count": {
            "type": "integer",
            "minimum": 1
          },
          "counts": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "stable",
              "marginal",
              "unstable"
            ],
            "properties": {
              "stable": {
                "type": "integer",
                "minimum": 0
              },
              "marginal": {
                "type": "integer",
                "minimum": 0
              },
              "unstable": {
                "type": "integer",
                "minimum": 0
              }
            }
          },
          "cases": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "case_id",
                "report"
              ],
              "properties": {
                "case_id": {
                  "type": "string"
                },
                "report": {
                  "$ref": "#/$defs/stability_report"
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "stability_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classification",
        "structural_retention",
        "temporal_consistency",
        "causal_deformation",
        "geometric_integrity",
        "confidence",
        "coherence_score",
        "metric_vector",
        "normalized_vector",
        "policy_version",
        "summary"
      ],
      "properties": {
        "classification": {
          "type": "string",
          "enum": [
            "stable",
            "marginal",
            "unstable"
          ]
        },
        "structural_retention": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "temporal_consistency": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "causal_deformation": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "geometric_integrity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "coherence_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "metric_vector": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "structural_retention",
            "temporal_consistency",
            "causal_deformation",
            "geometric_integrity"
          ],
          "properties": {
            "structural_retention": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "temporal_consistency": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "causal_deformation": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "geometric_integrity": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "normalized_vector": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "structural_retention",
            "temporal_consistency",
            "causal_stability",
            "geometric_integrity"
          ],
          "properties": {
            "structural_retention": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "temporal_consistency": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "causal_stability": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "geometric_integrity": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "policy_version": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        }
      }
    }
  }
}
